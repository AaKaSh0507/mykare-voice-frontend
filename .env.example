# ─────────────────────────────────────────────────────────────
# Environment Variables for mykare-voice-frontend
# ─────────────────────────────────────────────────────────────
# NOTE: All variables MUST be prefixed with VITE_ for Vite to
# expose them to the browser via import.meta.env.VITE_*
# Variables without the VITE_ prefix will NOT be available
# in client-side code.
# ─────────────────────────────────────────────────────────────

# URL of the mykare-voice-backend API server
VITE_BACKEND_URL=http://localhost:8000

# URL of the LiveKit server for real-time audio/video
VITE_LIVEKIT_URL=
